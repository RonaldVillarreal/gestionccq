# Renombra este archivo a .env y completa con tus credenciales de Appwrite.

# --- Frontend (Vite expone solo las VITE_*) ---
VITE_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=tu-project-id
VITE_APPWRITE_DB_ID=colegio

# --- Solo para el script de provisión (npm run setup:appwrite) ---
# API key de servidor con permisos de Databases. NO lleva prefijo VITE_,
# así que NUNCA llega al navegador. Bórrala o revócala cuando termines.
APPWRITE_API_KEY=tu-api-key-secreta
